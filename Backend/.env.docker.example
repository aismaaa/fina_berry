# ─── Fina Berry ───────────────────────────────────────────

# Docker image (dari Docker Hub)
DOCKER_IMAGE=shabeuy/finaberry-backend
IMAGE_TAG=v1.0.0

# App
APP_URL=https://www.finnaberry.my.id
APP_KEY=

# Ports host (tidak bentrok dengan Tomodachi yang pakai port 80)
APP_PORT=8081
PMA_PORT=8082

# Database
DB_DATABASE=finaberry
DB_USERNAME=finaberry_user
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Midtrans
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=true
