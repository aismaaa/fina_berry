# ─── n8n Production Config ────────────────────────────────
# n8n pakai MySQL dari finaberry_db (bukan database baru)
# Pastikan user ini sudah ada di finaberry_db

# Database MySQL untuk n8n (pakai finaberry_db yang sudah jalan)
N8N_DB_DATABASE=n8n
N8N_DB_USER=finaberry_user       # sama dengan DB_USERNAME di finaberry .env
N8N_DB_PASSWORD=                 # sama dengan DB_PASSWORD di finaberry .env

# n8n Configuration
N8N_SECURE_COOKIE=false
